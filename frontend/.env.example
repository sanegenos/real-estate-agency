# Frontend Environment Variables

# API endpoint for the frontend application
REACT_APP_API_URL=https://api.example.com

# URL of the authentication service
REACT_APP_AUTH_URL=https://auth.example.com

# Public Key for API Integration
REACT_APP_PUBLIC_KEY=your_public_key_here

# Base URL for assets
REACT_APP_ASSETS_URL=https://assets.example.com

# Other necessary environment variables
REACT_APP_OTHER_VARIABLE=value_here